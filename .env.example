# Variables d'environnement requises au démarrage de l'application
# Copiez ce fichier en .env et renseignez les valeurs réelles

# --- Credentials Mega.nz (OBLIGATOIRES) ---
MEGA_EMAIL="ton_email_mega@example.com"
MEGA_PASSWORD="ton_mot_de_passe_mega"

# --- Dossier de destination sur Mega.nz ---
MEGA_FOLDER="seadrop_uploads"

# --- Taille maximale des fichiers acceptés (en Mo, défaut : 50) ---
MAX_FILE_SIZE_MB=50
